# Vorlage fuer die Impala-Zugangsdaten.
# Kopiere diese Datei zu ".env" und trage deine echten Werte ein.
# Die .env-Datei wird NICHT in Git eingecheckt (siehe .gitignore).

IMPALA_HOST=dein-impala-host.example.com
IMPALA_PORT=443
IMPALA_HTTP_PATH=cliservice
IMPALA_USER=dein-benutzername
IMPALA_PASSWORD=dein-passwort

# Nur fuer scheduler.py / pipeline_spark.py noetig (PySpark braucht JDK 17).
# Optional: nur setzen, wenn dein System-JAVA_HOME nicht schon auf ein
# JDK 17 zeigt. Pfad zu deiner lokalen JDK-17-Installation, z.B.:
# Windows:  C:\Users\<du>\AppData\Local\Programs\Eclipse Adoptium\jdk-17.x.x-hotspot
# Linux/Mac: /usr/lib/jvm/temurin-17-jdk
JAVA_HOME_JDK17=
